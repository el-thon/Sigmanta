# Supabase PostgreSQL database.
# Format Supabase umumnya:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Untuk akses database Docker dari host, gunakan:
DATABASE_URL="postgresql://sigmanta:sigmanta@localhost:5433/sigmanta?schema=public"
JWT_SECRET="change-this-secret-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Local storage. File disimpan di filesystem project/server.
LOCAL_STORAGE_DIR="public/uploads"
NEXT_PUBLIC_LOCAL_STORAGE_URL="/uploads"
