# Supabase PostgreSQL database.
# Format Supabase umumnya:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Untuk akses database Docker dari host, gunakan:
DATABASE_URL="postgresql://sigmanta:sigmanta@localhost:5434/sigmanta?schema=public"
JWT_SECRET="change-this-secret-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 storage untuk upload file, seperti foto profil.
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET="sigmanta-uploads"
R2_ACCESS_KEY_ID="<ACCESS_KEY_ID>"
R2_SECRET_ACCESS_KEY="<SECRET_ACCESS_KEY>"
R2_PUBLIC_URL="/api/storage"

# Public geospatial datasets.
# OpenAQ mengirim key lewat header X-API-Key, tetapi nama env di aplikasi tetap OPENAQ_API_KEY.
OPENAQ_API_KEY=""
NASA_FIRMS_MAP_KEY=""
